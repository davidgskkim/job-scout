# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Gemini — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Gmail — use a Gmail App Password (NOT your real password)
# Enable at: https://myaccount.google.com/apppasswords
# Paste the 16-character password with NO spaces or dashes
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your16charpassword

# Where to send job alerts (usually same as GMAIL_USER)
TO_EMAIL=your@gmail.com
